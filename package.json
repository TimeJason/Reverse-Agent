{
  "name": "software-analysis-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "lint": "pnpm -r --sort build && eslint \"packages/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --sort build && pnpm -r --sort typecheck",
    "test": "pnpm -r --sort build && pnpm -r --sort test && pnpm test:architecture",
    "test:architecture": "node scripts/check-package-boundaries.mjs",
    "test:contract": "node scripts/skip-suite.mjs contract",
    "test:golden": "node scripts/skip-suite.mjs golden",
    "test:e2e": "node scripts/skip-suite.mjs e2e",
    "test:security": "node scripts/skip-suite.mjs security",
    "test:bench": "node scripts/skip-suite.mjs bench"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
